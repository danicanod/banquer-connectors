# Banquer Connectors - Environment Configuration
# Copy this file as .env and fill in your credentials
# NEVER commit your .env file to version control

# ============================================================================
# BANESCO CREDENTIALS (Hybrid: Playwright login + HTTP fetch)
# ============================================================================

# Your Banesco username (cedula without dots)
BANESCO_USERNAME=V12345678

# Your Banesco password
BANESCO_PASSWORD=your_password_here

# Security questions mapping (required for full login)
# Format: keyword1:answer1,keyword2:answer2
# The system will match keywords against question text (case-insensitive)
# Example: BANESCO_SECURITY_QUESTIONS=anime:Naruto,mascota:Firulais,color:azul
BANESCO_SECURITY_QUESTIONS=anime:Naruto,mascota:Firulais

# ============================================================================
# BNC CREDENTIALS (Pure HTTP - no browser needed)
# ============================================================================

# Your ID (cedula with V prefix)
BNC_ID=V12345678

# Your card number (16 digits)
BNC_CARD=1234567890123456

# Your BNC password
BNC_PASSWORD=your_password_here

# ============================================================================
# FACEBANK CREDENTIALS (PR) — Playwright login + in-browser scraping
# ============================================================================
# Facebank online banking is a COBIS/Angular SPA. Login runs in a browser and a
# 5-character one-time code is emailed to you; by default the example prompts for
# it on the terminal (or pass an otpProvider callback in code).

# Your Facebank username
FACEBANK_USERNAME=your_username_here

# Your Facebank password
FACEBANK_PASSWORD=your_password_here

# Optional — only needed if your account triggers the security-image step-up
# screen (a rare, risk-based challenge). These map to COBIS's image "alias" (the
# secret word) and "imagenid" (which registered image is yours).
# FACEBANK_SECRET_WORD=your_image_alias
# FACEBANK_SECRET_IMAGE=your_image_id

# Enable verbose Facebank logging
# FACEBANK_DEBUG=true

# ============================================================================
# OPTIONAL SETTINGS
# ============================================================================

# Timeout in milliseconds (default: 30000)
TIMEOUT=30000

# Enable debug logging for BNC HTTP client
# BNC_DEBUG=true

# ============================================================================
# USAGE
# ============================================================================

# 1. Copy this file: cp env.example .env
# 2. Fill in your credentials
# 3. Run examples:
#    npm run example:banesco          # Banesco (Playwright)
#    npm run example:banesco-hybrid   # Banesco (recommended hybrid mode)
#    npm run example:bnc              # BNC (pure HTTP, fast)
#    npm run example:facebank         # Facebank (Playwright login + OTP)
